# Unity .gitattributes — Endless Courier 2D (Assignment 4)
# Ensures consistent line endings and binary handling across all platforms
# so the project reproduces identically after git clone on Windows/Mac/Linux
#
# Requires Git LFS installed: https://git-lfs.github.com
# Run once after clone: git lfs install

# ── Attribute macros ──────────────────────────────────────────────────────────
[attr]lfs               filter=lfs diff=lfs merge=lfs -text
[attr]unity-json        eol=lf linguist-language=json
[attr]unity-yaml        merge=unityyamlmerge eol=lf linguist-language=yaml

# ── Unity C# source ───────────────────────────────────────────────────────────
*.cs                    text eol=lf diff=csharp
*.cginc                 text eol=lf
*.compute               text eol=lf linguist-language=hlsl
*.hlsl                  text eol=lf linguist-language=hlsl
*.shader                text eol=lf

# ── Unity JSON files ──────────────────────────────────────────────────────────
*.asmdef                unity-json
*.asmref                unity-json
*.inputactions          unity-json
*.shadergraph           unity-json
*.shadersubgraph        unity-json
*.index                 unity-json

# ── Unity UI Toolkit ──────────────────────────────────────────────────────────
*.tss                   text eol=lf diff=css
*.uss                   text eol=lf diff=css
*.uxml                  text eol=lf linguist-language=xml

# ── Unity YAML (scene, prefab, asset files) ───────────────────────────────────
